# 文件路径: configs/AP-Storage-Overrides.config

# 1. 移除科学上网、代理与 DNS 防污染 (AP不需要，后续也可 opkg install)
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Geoview=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=n
CONFIG_PACKAGE_luci-app-smartdns=n

# 2. 移除高级流控与行为管理 (AP不负责分配带宽，由主路由处理)
CONFIG_PACKAGE_luci-app-sqm=n
CONFIG_PACKAGE_sqm-scripts-nss=n
CONFIG_PACKAGE_luci-app-oaf=n
CONFIG_PACKAGE_luci-app-3cat=n

# 3. 移除 VPN 与内网穿透 (通常由主路由负责)
CONFIG_PACKAGE_luci-proto-wireguard=n
CONFIG_PACKAGE_luci-app-frps=n
CONFIG_PACKAGE_luci-app-frpc=n

# 4. 移除独立下载工具 (后续可通过命令或后台自行安装 Aria2 等)
CONFIG_PACKAGE_luci-app-aria2=n
CONFIG_PACKAGE_ariang=n

# 5. 移除其他非必要的辅助网络工具与服务端
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_ddns-scripts-cloudflare=n
CONFIG_PACKAGE_luci-app-upnp=n
CONFIG_PACKAGE_luci-app-wol=n
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-app-wechatpush=n
CONFIG_PACKAGE_luci-app-banip=n
CONFIG_PACKAGE_luci-app-acme=n
CONFIG_PACKAGE_acme-acmesh-dnsapi=n
CONFIG_PACKAGE_luci-app-arpbind=n
CONFIG_PACKAGE_luci-app-watchcat=n
CONFIG_PACKAGE_luci-app-ttyd=n
CONFIG_PACKAGE_luci-app-cpufreq=n
