# 文件路径: configs/MainRouter-Overrides.config

# 1. 彻底关闭 WiFi 驱动和组件
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_luci-app-wifischedule=n

# 2. 删除不需要的代理与 VPN
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-proto-wireguard=n
CONFIG_PACKAGE_luci-app-frps=n
CONFIG_PACKAGE_luci-app-frpc=n

# 3. 删除不需要的存储与外设共享
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-aria2=n
CONFIG_PACKAGE_luci-app-diskman=n
CONFIG_PACKAGE_luci-app-hd-idle=n
CONFIG_PACKAGE_luci-app-usb-printer=n
CONFIG_PACKAGE_ariang=n

# 4. 删除其他不需要的辅助插件
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-app-wechatpush=n
CONFIG_PACKAGE_luci-app-acme=n
CONFIG_PACKAGE_acme-acmesh-dnsapi=n
